---
interface Props {
  title: string
  text: string
  link?: string
}

const { title, text, link } = Astro.props

// Parse markdown-style links [text](url) in the text prop
function parseTextWithLinks(input: string) {
  const parts: Array<{ type: 'text'; value: string } | { type: 'link'; text: string; url: string }> = []
  const regex = /\[([^\]]+)\]\(([^)]+)\)/g
  let lastIndex = 0
  let match

  while ((match = regex.exec(input)) !== null) {
    if (match.index > lastIndex) {
      parts.push({ type: 'text', value: input.slice(lastIndex, match.index) })
    }
    parts.push({ type: 'link', text: match[1], url: match[2] })
    lastIndex = match.index + match[0].length
  }

  if (lastIndex < input.length) {
    parts.push({ type: 'text', value: input.slice(lastIndex) })
  }

  return parts
}

const textParts = parseTextWithLinks(text)
---

<div class="group py-3">
  <h3 class="text-slate-900 font-medium text-sm">
    {link ? (
      <a href={link} target="_blank" rel="noopener noreferrer" class="hover:underline decoration-slate-300 underline-offset-4">
        {title}
        <span class="sr-only">(opens in new tab)</span>
      </a>
    ) : (
      title
    )}
  </h3>
  <p class="text-slate-600 text-sm mt-0.5 leading-relaxed">
    {textParts.map((part) =>
      part.type === 'link' ? (
        <a href={part.url} target="_blank" rel="noopener noreferrer" class="text-slate-900 underline decoration-slate-300 underline-offset-4 hover:decoration-slate-500">{part.text}</a>
      ) : (
        part.value
      )
    )}
  </p>
</div>
